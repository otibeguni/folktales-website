---
import { Schema } from "astro-seo-schema";
import "@/styles/global.css";
import Footer from "@/components/Footer.astro";
import Navbar from "@/components/Navbar.astro";
import { t } from "@/utils/site-text";
import { buildCanonicalUrl, type AlternateLink } from "@/utils/seo";

interface Props {
  schema?: object | null;
  title?: string | null;
  description?: string | null;
  lang?: string;
  canonicalUrl?: string;
  alternateLinks?: AlternateLink[];
}

const {
  schema = null,
  title = null,
  description = null,
  lang = "en",
  canonicalUrl = buildCanonicalUrl(Astro.url.pathname, Astro.site),
  alternateLinks = [],
} = Astro.props as Props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />

    {schema && <meta property="og:type" content="article" />}
    {schema && <meta property="og:title" content={schema.name} />}
    {schema && <meta property="og:image" content={schema.image} />}
    {schema && <meta property="og:url" content={schema.url} />}

    <link rel="icon" type="image/png" href="/otibeguni-logo.png" />
    <link rel="canonical" href={canonicalUrl} />
    {
      alternateLinks.map(({ hreflang, href }) => (
        <link rel="alternate" hreflang={hreflang} href={href} />
      ))
    }
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
      integrity="sha512-SnH5WK+bZxgPHs44uWIX+LLJAJ9/2PkPKZ5QiAj6Ta86w+fsb2TkcmfRyVX3pBnMFcV7oQPJkl9QevSCWr3W6A=="
      crossorigin="anonymous"
      referrerpolicy="no-referrer"
    />
    <meta name="generator" content={Astro.generator} />
    <title>{title ?? t("common.siteTitle")}</title>
    <meta name="description" content={description ?? t("common.siteDescription")} />
    {schema && <Schema item={schema} />}
  </head>
  <body>
    <Navbar />
    <main class="container mx-auto pt-4 pb-12">
      <slot />
    </main>
    <Footer />
  </body>
</html>
