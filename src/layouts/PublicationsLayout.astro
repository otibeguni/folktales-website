---
import { Schema } from "astro-seo-schema";
import "@/styles/global.css";
import AppShell from "@/components/AppShell.astro";
import type { IBreadcrumbs } from "@/types";
import { buildCanonicalUrl, normalizeBreadcrumbs, type AlternateLink } from "@/utils/seo";

interface Props {
  schema?: object | null;
  title?: string;
  description?: string;
  lang?: string;
  canonicalUrl?: string;
  alternateLinks?: AlternateLink[];
  breadcrumbs?: IBreadcrumbs[];
}

const {
  schema = null,
  title = "Publications | Otibeguni",
  description =
    "Books, art books, and research projects that celebrate Bengali and indigenous folklore.",
  lang = "en",
  canonicalUrl = buildCanonicalUrl(Astro.url.pathname, Astro.site),
  alternateLinks = [],
  breadcrumbs = [],
} = Astro.props as Props;
const { structuredData: breadcrumbStructuredData } = normalizeBreadcrumbs(
  breadcrumbs,
  Astro.site,
);
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="/otibeguni-logo.png" />
    <link rel="canonical" href={canonicalUrl} />
    {
      alternateLinks.map(({ hreflang, href }) => (
        <link rel="alternate" hreflang={hreflang} href={href} />
      ))
    }
    <meta name="description" content={description} />
    <title>{title}</title>
    {schema && <Schema item={schema} />}
    {breadcrumbStructuredData && <Schema item={breadcrumbStructuredData} />}
  </head>
  <body class="bg-white text-slate-900">
    <AppShell breadcrumbs={breadcrumbs} site={Astro.site} currentPath={Astro.url.pathname}>
      <section>
        <div class="mx-auto max-w-4xl pb-12 pt-2 sm:pb-16 sm:pt-4 lg:pb-20 lg:pt-6">
          <slot name="hero" />
        </div>
      </section>
      <section class="mx-auto max-w-4xl space-y-12 pb-12 sm:pb-16 lg:pb-20">
        <slot />
      </section>
    </AppShell>
  </body>
</html>
