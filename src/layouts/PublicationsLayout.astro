---
import { Schema } from "astro-seo-schema";
import "@/styles/global.css";
import Footer from "@/components/Footer.astro";
import Navbar from "@/components/Navbar.astro";
import type { IBreadcrumbs } from "@/types";
import { buildCanonicalUrl, normalizeBreadcrumbs, type AlternateLink } from "@/utils/seo";

interface Props {
  schema?: object | null;
  title?: string;
  description?: string;
  lang?: string;
  canonicalUrl?: string;
  alternateLinks?: AlternateLink[];
  breadcrumbs?: IBreadcrumbs[];
}

const {
  schema = null,
  title = "Publications | Otibeguni",
  description =
    "Books, art books, and research projects that celebrate Bengali and indigenous folklore.",
  lang = "en",
  canonicalUrl = buildCanonicalUrl(Astro.url.pathname, Astro.site),
  alternateLinks = [],
  breadcrumbs = [],
} = Astro.props as Props;
const { structuredData: breadcrumbStructuredData } = normalizeBreadcrumbs(
  breadcrumbs,
  Astro.site,
);
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="/otibeguni-logo.png" />
    <link rel="canonical" href={canonicalUrl} />
    {
      alternateLinks.map(({ hreflang, href }) => (
        <link rel="alternate" hreflang={hreflang} href={href} />
      ))
    }
    <meta name="description" content={description} />
    <title>{title}</title>
    {schema && <Schema item={schema} />}
    {breadcrumbStructuredData && <Schema item={breadcrumbStructuredData} />}
  </head>
  <body class="bg-white text-slate-900">
    <Navbar breadcrumbs={breadcrumbs} site={Astro.site} />
    <main
      class:list={[
        "container mx-auto min-h-screen px-4 pb-12",
        breadcrumbs.length > 0 ? "pt-14" : "",
      ]}
    >
      <section class="relative isolate overflow-hidden">
        <div
          class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_top,_rgba(59,130,246,0.12)_0,_transparent_42%),radial-gradient(circle_at_20%_20%,_rgba(14,165,233,0.12)_0,_transparent_36%),radial-gradient(circle_at_80%_0,_rgba(56,189,248,0.14)_0,_transparent_32%)]"
          aria-hidden="true"
        />
        <div class="mx-auto max-w-4xl py-12 sm:py-16 lg:py-20">
          <slot name="hero" />
        </div>
      </section>
      <section class="-mt-6 mx-auto max-w-4xl space-y-12 sm:-mt-10">
        <slot />
      </section>
    </main>
    <Footer />
  </body>
</html>
