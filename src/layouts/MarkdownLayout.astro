---
import { Schema } from "astro-seo-schema";
import "@/styles/global.css";
import Footer from "@/components/Footer.astro";
import Navbar from "@/components/Navbar.astro";
import { t } from "@/utils/site-text";
import { buildCanonicalUrl, type AlternateLink } from "@/utils/seo";

interface Props {
  schema?: object | null;
  title?: string | null;
  description?: string | null;
  lang?: string;
  canonicalUrl?: string;
  alternateLinks?: AlternateLink[];
}

const {
  schema = null,
  title = null,
  description = null,
  lang = "en",
  canonicalUrl = buildCanonicalUrl(Astro.url.pathname, Astro.site),
  alternateLinks = [],
} = Astro.props as Props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="/otibeguni-logo.png" />
    <link rel="canonical" href={canonicalUrl} />
    {
      alternateLinks.map(({ hreflang, href }) => (
        <link rel="alternate" hreflang={hreflang} href={href} />
      ))
    }
    <meta name="generator" content={Astro.generator} />
    <title>{title ?? t("common.siteTitle")}</title>
    <meta name="description" content={description ?? t("common.siteDescription")} />
    {schema && <Schema item={schema} />}
  </head>
  <body>
    <Navbar />
    <main class="container mx-auto py-12">
      <article class="prose mx-auto max-w-3xl px-4 pb-12">
        <slot />
      </article>
    </main>
    <Footer />
  </body>
</html>
