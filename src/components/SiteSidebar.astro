---
import { isCurrentNavPath, siteNav } from "@/components/site-nav";
import { localizePath } from "@/utils/site-text";

interface Props {
  currentPath?: string;
}

const { currentPath = "/" } = Astro.props as Props;
---

<aside
  id="site-sidebar"
  class="site-sidebar sidebar-closed fixed inset-y-0 left-0 z-50 flex w-[18rem] max-w-[calc(100vw-2rem)] flex-col border-r border-slate-200 bg-white shadow-2xl shadow-slate-900/12 lg:sticky lg:top-0 lg:z-20 lg:h-screen lg:w-auto lg:max-w-none lg:shadow-none"
  aria-hidden="true"
  data-sidebar-panel
  data-pagefind-ignore
>
  <div class="flex items-center justify-between gap-3 border-b border-slate-200 px-4 py-4 sm:px-5">
    <a
      href={localizePath("/")}
      class="site-sidebar-brand min-w-0 text-left text-lg font-semibold tracking-tight text-slate-900 no-underline"
      style="visibility: hidden; pointer-events: none;"
    >
      Otibeguni
    </a>

    <button
      type="button"
      class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-xl border border-slate-300 bg-slate-50 text-slate-700 shadow-sm transition hover:border-slate-400 hover:bg-slate-100 hover:text-slate-900"
      aria-label="Close navigation menu"
      data-sidebar-close
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
        class="h-5 w-5 stroke-current"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="1.8"
          d="M6 6l12 12M6 18L18 6"
        ></path>
      </svg>
    </button>
  </div>

  <div class="min-h-0 flex-1 overflow-y-auto px-3 py-5 sm:px-4">
    <nav aria-label="Primary" class="space-y-6">
      <div class="space-y-1.5">
        {
          siteNav
            .filter((item) => item.href)
            .map((item) => {
              const isCurrent = isCurrentNavPath(currentPath, item.href);

              return (
                <a
                  href={item.href!}
                  aria-current={isCurrent ? "page" : undefined}
                  class:list={[
                    "flex items-center gap-3 rounded-xl px-3 py-2.5 text-[0.97rem] font-medium no-underline transition",
                    isCurrent
                      ? "bg-primary text-primary-content shadow-sm"
                      : "text-slate-700 hover:bg-slate-100 hover:text-slate-900",
                  ]}
                  data-sidebar-link
                >
                  <span class="truncate">{item.label}</span>
                </a>
              );
            })
        }
      </div>

      {
        siteNav
          .filter((item) => item.children?.length)
          .map((group) => {
            const hasActiveChild = group.children?.some((child) =>
              isCurrentNavPath(currentPath, child.href),
            );

            return (
              <section class="space-y-2.5">
                <div
                  class:list={[
                    "px-3 text-[0.68rem] font-semibold uppercase tracking-[0.18em]",
                    hasActiveChild ? "text-primary" : "text-slate-500",
                  ]}
                >
                  {group.label}
                </div>

                <div class="space-y-1">
                  {group.children?.map((child) => {
                    const isCurrent = isCurrentNavPath(currentPath, child.href);
                    const isExternal = !child.href.startsWith("/");

                    return (
                      <a
                        href={child.href}
                        aria-current={isCurrent ? "page" : undefined}
                        class:list={[
                          "flex items-center justify-between gap-3 rounded-xl px-3 py-2.5 text-sm no-underline transition",
                          isCurrent
                            ? "bg-primary/8 font-semibold text-primary"
                            : "text-slate-600 hover:bg-slate-100 hover:text-slate-900",
                        ]}
                        data-sidebar-link
                      >
                        <span class="truncate">{child.label}</span>
                        {isExternal && (
                          <svg
                            xmlns="http://www.w3.org/2000/svg"
                            fill="none"
                            viewBox="0 0 24 24"
                            class="h-3.5 w-3.5 shrink-0 stroke-current opacity-60"
                          >
                            <path
                              stroke-linecap="round"
                              stroke-linejoin="round"
                              stroke-width="1.8"
                              d="M7 17L17 7M9 7h8v8"
                            ></path>
                          </svg>
                        )}
                      </a>
                    );
                  })}
                </div>
              </section>
            );
          })
      }
    </nav>
  </div>
</aside>
