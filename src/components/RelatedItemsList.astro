---
import { localizePath } from "@/utils/site-text";
import { formatTopicTags } from "@/utils/topic-tags";

// A generic interface for any item we want to display in the list
interface Item {
  name: string;
  type?: string;
  types?: string[];
  meta?: string;
  url?: string;
  isExternal?: boolean;
}

interface Props {
  title?: string; // The title for the section
  items?: Item[];
}

const { title, items } = Astro.props;

if (!items || items.length === 0) {
  return null;
}
---
<div class:list={['flex flex-col gap-3', title ? 'mt-8' : 'mt-4']}>
  {title && <h3 class="mb-4 text-2xl font-bold">{title}</h3>}
  <div class="flex flex-col gap-3">
    {
      items.map((item) => {
        const linkUrl = item.isExternal ? item.url : localizePath(item.url);

        if (!linkUrl) return null;

        const metadataParts = [
          item.types ? formatTopicTags(item.types) : item.type,
          item.meta,
        ].filter(Boolean);
        const metadata = metadataParts.join(' · ');

        return (
          <a
            href={linkUrl}
            target={item.isExternal ? '_blank' : '_self'}
            rel={item.isExternal ? 'noopener noreferrer' : null}
            class="bg-base-200/50 hover:bg-base-200 flex rounded-xl px-4 py-4 no-underline transition-all duration-300 hover:shadow-sm md:px-5 md:py-5"
          >
            <div class="flex min-w-0 flex-grow flex-col gap-2">
              <h4 class="text-base font-bold leading-snug md:text-lg">
                {item.name}
              </h4>
              {metadata && (
                <p class="mt-auto text-sm leading-snug text-slate-600 md:text-base">
                  {metadata}
                </p>
              )}
            </div>
          </a>
        );
      })
    }
  </div>
</div>
