---
import { localizePath } from "@/utils/site-text";
import { sortTopicTags } from "@/utils/topic-tags";

interface Item {
  name: string;
  subtitle?: string;
  badges?: string[];
  type?: string;
  types?: string[];
  meta?: string;
  url?: string;
  isExternal?: boolean;
}

interface Props {
  title?: string;
  items?: Item[];
  emptyMessage?: string;
  layout?: "cards" | "topic-chips";
}

const { title, items, emptyMessage, layout = "cards" } = Astro.props;
const hasActions = Astro.slots.has("actions");
const useTopicChips = layout === "topic-chips";

if ((!items || items.length === 0) && !title && !hasActions) {
  return null;
}
---

<div class:list={["flex flex-col gap-3", title ? "mt-8" : "mt-4"]}>
  {
    (title || hasActions) && (
      <div class="mb-4 flex flex-wrap items-center justify-between gap-3">
        {title ? <h3 class="text-2xl font-bold">{title}</h3> : <div />}
        {hasActions && <slot name="actions" />}
      </div>
    )
  }
  {
    items && items.length > 0 ? (
      <div class:list={useTopicChips ? "flex flex-wrap gap-3" : "flex flex-col gap-4"}>
        {
          items.map((item) => {
            const linkUrl = item.isExternal ? item.url : localizePath(item.url);

            if (!linkUrl) return null;

            const subtitle = item.subtitle ?? item.meta;
            const badges = item.badges ?? [
              ...(item.types ? sortTopicTags(item.types) : []),
              ...(item.type ? [item.type] : []),
            ];

            return (
              <a
                href={linkUrl}
                target={item.isExternal ? "_blank" : "_self"}
                rel={item.isExternal ? "noopener noreferrer" : null}
                class:list={
                  useTopicChips
                    ? "inline-flex max-w-full items-center rounded-[14px] border border-[#7811a7] bg-white px-3.5 py-2 text-sm font-semibold text-slate-900 no-underline transition hover:border-[#01abf2] md:text-[0.95rem]"
                    : "bg-base-100 hover:bg-base-200/60 flex flex-col gap-3 rounded-2xl border border-base-300 px-4 py-4 no-underline transition md:px-5 md:py-5"
                }
              >
                {
                  useTopicChips ? (
                    <span class="block min-w-0 truncate">{item.name}</span>
                  ) : (
                    <div class="min-w-0">
                      <h4 class="mt-0 text-lg font-semibold leading-snug md:text-xl">
                        {item.name}
                      </h4>
                      {subtitle && (
                        <p class="mt-1 text-sm leading-6 text-slate-600 md:text-base">
                          {subtitle}
                        </p>
                      )}
                      {badges.length > 0 && (
                        <div class="mt-3 flex flex-wrap items-center gap-2">
                          {badges.map((badge) => (
                            <span class="badge badge-soft badge-primary">{badge}</span>
                          ))}
                        </div>
                      )}
                    </div>
                  )
                }
              </a>
            );
          })
        }
      </div>
    ) : emptyMessage ? (
      <div class="rounded-2xl border border-dashed border-base-300 px-5 py-6 text-sm text-slate-500">
        {emptyMessage}
      </div>
    ) : null
  }
</div>
