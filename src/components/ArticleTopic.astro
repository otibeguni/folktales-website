---
import Breadcrumbs from './Breadcrumbs.astro';
import type { IStory } from '@/types';
import RelatedItemsList from '@/components/RelatedItemsList.astro';
import { sortTopicTags } from '@/utils/topic-tags';

const { topic, stories, books, resources } = Astro.props;
const sortedTags = sortTopicTags(topic.types ?? []);

const relatedStories = stories.map(({ frontmatter }: { frontmatter: IStory }) => ({
  name: frontmatter.title,
  type: frontmatter.category,
  url: `/stories/${frontmatter.slug}`,
  isExternal: false,
}));

const relatedBooks = books
  .map((book) => {
    const bookUrl = book.library_url || book.url;

    if (!bookUrl) {
      return null;
    }

    return {
      name: book.name,
      type: 'Book',
      meta: book.author || '',
      url: bookUrl,
      isExternal: true,
    };
  })
  .filter(Boolean);

const relatedResources = resources
  .map((resource) => {
    if (!resource.url) {
      return null;
    }

    return {
      name: resource.title,
      type: resource.type,
      url: resource.url,
      isExternal: true,
    };
  })
  .filter(Boolean);
---

<div class="min-h-screen">
  <article class="prose mx-auto max-w-4xl px-4 pb-12">
    <Breadcrumbs
      menus={[{ label: 'Topics', href: '/topics' }, { label: topic.item }]}
    />
    <h1 class="mb-4 text-5xl leading-16">{topic.item}</h1>
    <div class="flex flex-wrap gap-2">
      {sortedTags.map((tag) => (
        <span class="badge badge-soft badge-primary">{tag}</span>
      ))}
    </div>

    <div class="divider"></div>

    {topic.description && <p class="mb-8">{topic.description}</p>}

    {
      relatedStories.length > 0 && (
        <>
          <h1 class="text-3xl">Stories</h1>
          <RelatedItemsList
            title=""
            items={relatedStories}
          />
        </>
      )
    }

    {
      relatedBooks.length > 0 && (
        <>
          <h1 class="mt-8 text-3xl">Related Books</h1>
          <RelatedItemsList
            title=""
            items={relatedBooks}
          />
        </>
      )
    }

    {
      relatedResources.length > 0 && (
        <RelatedItemsList
          title="Related Resources"
          items={relatedResources}
        />
      )
    }
  </article>
</div>
