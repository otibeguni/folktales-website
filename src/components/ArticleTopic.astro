---
import type { IStory } from '@/types';
import BookListItem from '@/components/BookListItem';
import RelatedItemsList from '@/components/RelatedItemsList.astro';
import TopicRelationEditor from '@/components/TopicRelationEditor';
import { sortTopicTags } from '@/utils/topic-tags';

const {
  topic,
  stories,
  books,
  resources,
  relationSections = [],
  isDev = false,
  availableTopics = [],
  currentTopicRelations = [],
} = Astro.props;
const sortedTags = sortTopicTags(topic.types ?? []);

const relatedStories = stories.map(({ frontmatter }: { frontmatter: IStory }) => ({
  name: frontmatter.title,
  badges: [frontmatter.category],
  url: `/stories/${frontmatter.slug}`,
  isExternal: false,
}));

const relatedResources = resources
  .map((resource) => {
    if (!resource.url) {
      return null;
    }

    return {
      name: resource.title,
      badges: [resource.type],
      url: resource.url,
      isExternal: true,
    };
  })
  .filter(Boolean);
---

<div class="min-h-screen">
  <article class="prose mx-auto max-w-4xl px-4 pb-12">
    <h1 class="mb-4 text-5xl leading-16">{topic.item}</h1>
    <div class="flex flex-wrap gap-2">
      {sortedTags.map((tag) => (
        <span class="badge badge-soft badge-primary">{tag}</span>
      ))}
    </div>

    <div class="divider"></div>

    {topic.description && <p class="mb-8">{topic.description}</p>}

    {
      (relationSections.length > 0 || isDev) && (
        <section class="not-prose mb-8">
          <div class="mb-4 flex flex-wrap items-center justify-between gap-3">
            <h2 class="text-3xl font-bold">Topic Relationships</h2>
            {
              isDev && (
                <TopicRelationEditor
                  client:load
                  topicSlug={topic.slug}
                  topicItem={topic.item}
                  availableTopics={availableTopics}
                  currentRelations={currentTopicRelations}
                />
              )
            }
          </div>

          <div class="flex flex-col gap-3">
            {
              relationSections.length > 0 ? (
                relationSections.map((section) => (
                  <RelatedItemsList
                    title={section.title}
                    items={section.items.map((item) => ({
                      name: item.item,
                      types: item.types,
                      url: item.href,
                      isExternal: false,
                    }))}
                    layout="topic-chips"
                  />
                ))
              ) : (
                <div class="rounded-2xl border border-dashed border-base-300 px-5 py-6 text-sm text-slate-500">
                  No topic relationships yet.
                </div>
              )
            }
          </div>
        </section>
      )
    }

    {
      relatedStories.length > 0 && (
        <>
          <h1 class="text-3xl">Stories</h1>
          <RelatedItemsList
            title=""
            items={relatedStories}
          />
        </>
      )
    }

    {
      books.length > 0 && (
        <>
          <h1 class="mt-8 text-3xl">Related Books</h1>
          <div class="not-prose mt-4 flex flex-col gap-4">
            {books.map((book) => (
              <BookListItem book={book} />
            ))}
          </div>
        </>
      )
    }

    {
      relatedResources.length > 0 && (
        <RelatedItemsList
          title="Related Resources"
          items={relatedResources}
        />
      )
    }
  </article>
</div>
