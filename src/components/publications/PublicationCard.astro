---
import { localizePath } from "@/utils/site-text";

interface PublicationCardProps {
  title: string;
  description: string;
  cover: string;
  href?: string;
  meta?: string;
  layout?: 'stacked' | 'horizontal';
}

const {
  title,
  description,
  cover,
  href = '#',
  meta = '',
  layout = 'stacked',
} = Astro.props as PublicationCardProps;
const isExternal = /^https?:\/\//.test(href);
const target = isExternal ? '_blank' : undefined;
const rel = isExternal ? 'noreferrer noopener' : undefined;
const normalizedHref = isExternal ? href : localizePath(href);
const isHorizontal = layout === 'horizontal';
---

<a
  href={normalizedHref}
  target={target}
  rel={rel}
  class:list={[
    "group relative overflow-hidden rounded-2xl border border-slate-100 bg-white p-5 shadow-[0_16px_50px_-44px_rgba(15,23,42,0.6)] transition duration-200 hover:-translate-y-1 hover:shadow-[0_20px_60px_-40px_rgba(15,23,42,0.65)]",
    isHorizontal ? "flex items-start gap-5" : "flex h-full min-h-[520px] flex-col",
  ]}
>
  <div class:list={["relative overflow-hidden", isHorizontal ? "w-28 shrink-0 sm:w-36" : ""]}>
    <img
      src={cover}
      alt={`${title} cover`}
      loading="lazy"
      class:list={[
        "w-full object-cover transition duration-200 group-hover:scale-[1.03]",
        isHorizontal ? "aspect-[2/3]" : "aspect-[2/3]",
      ]}
    />
  </div>
  <div class:list={["flex flex-col gap-3", isHorizontal ? "min-w-0 flex-1 pt-0" : "flex-1 pt-4"]}>
    <h3 class="text-lg font-semibold leading-tight text-slate-900">{title}</h3>
    {meta && <p class="text-xs text-slate-500">{meta}</p>}
    <p class="text-sm text-slate-700">{description}</p>
  </div>
</a>
