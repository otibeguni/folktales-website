---
import FolkloreAtlas from "@/components/FolkloreAtlas";
import Layout from "@/layouts/Layout.astro";
import { getFolkloreAtlasEntries } from "@/utils/content";
import { t } from "@/utils/site-text";

const atlasEntries = await getFolkloreAtlasEntries();
const breadcrumbs = [
  { label: "Experiences", href: "/experiences" },
  { label: "Folklore Atlas", href: "/experiences/folklore-atlas" },
];
---

<Layout
  title={`${t("pages.experiences.atlasPageTitle")} | ${t("common.siteTitle")}`}
  description={t("pages.experiences.atlasPageDescription")}
  breadcrumbs={breadcrumbs}
>
  <div class="flex flex-col gap-8">
    <div class="flex flex-col gap-3">
      <h1 class="text-4xl font-bold tracking-tight text-slate-900 md:text-5xl">
        {t("pages.experiences.atlasPageTitle")}
      </h1>
      <p class="max-w-3xl text-base leading-7 text-slate-600 md:text-lg">
        {t("pages.experiences.atlasPageDescription")}
      </p>
    </div>

    <FolkloreAtlas
      entries={atlasEntries}
      labels={{
        relatedStoriesTitle: t("pages.experiences.atlasRelatedStoriesTitle"),
        relatedResourcesTitle: t("pages.experiences.atlasRelatedResourcesTitle"),
        noStoriesLabel: t("pages.experiences.atlasNoStoriesLabel"),
        panelPrompt: t("pages.experiences.atlasPanelPrompt"),
        markerCountLabel: t("pages.experiences.atlasMarkerCountLabel"),
      }}
      client:load
    />
  </div>
</Layout>
