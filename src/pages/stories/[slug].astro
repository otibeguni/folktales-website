---
import Layout from "@/layouts/Layout.astro";
import StoryHeader from "../../components/StoryHeader.astro";
import StoryMetadata from "../../components/StoryMetadata.astro";
import StoryReadAloudControl from "../../components/StoryReadAloudControl.astro";
import ArticleBody from "../../components/ArticleBody.astro";
import RelatedItemsList from "../../components/RelatedItemsList.astro";
import StoryCollectionList from "../../components/StoryCollectionList.astro";
import StoryRelationEditor from "../../components/StoryRelationEditor";
import BlogCard from "@/components/blog/BlogCard";
import {
  bookHasDetailPage,
  findStoryTranslation,
  getAllBooks,
  getAllResources,
  getAllStoryCollections,
  getAllStoryMetadata,
  getAllStories,
  getAllTopics,
  getBookDetailPath,
  getStoryCollectionsForStory,
  getStoryRouteSlug,
  getStoriesByLanguage,
  indexStoryCollectionsByStorySlug,
  indexEntriesBySlug,
  renderEntry,
  resolveStoryMetadata,
} from "@/utils/content";
import { buildCanonicalUrl } from "@/utils/seo";
import { getBlogPosts } from "@/utils/storyblok-blog";

export async function getStaticPaths() {
  const stories = await getStoriesByLanguage("en");
  return stories.map((story) => ({
    params: { slug: getStoryRouteSlug(story) },
    props: { story },
  }));
}

const { story } = Astro.props;
const { Content } = await renderEntry(story);

const [allStories, allTopics, allBooks, allResources, allStoryMetadata, allStoryCollections] = await Promise.all([
  getAllStories(),
  getAllTopics(),
  getAllBooks(),
  getAllResources(),
  getAllStoryMetadata(),
  getAllStoryCollections(),
]);
const allBlogs = await getBlogPosts();

const topicBySlug = indexEntriesBySlug(allTopics);
const bookBySlug = indexEntriesBySlug(allBooks);
const resourceBySlug = indexEntriesBySlug(allResources);
const storyMetadataBySlug = indexEntriesBySlug(allStoryMetadata);
const storyCollectionsByStorySlug = indexStoryCollectionsByStorySlug(allStoryCollections);
const storyRouteSlug = getStoryRouteSlug(story);
const resolvedStory = resolveStoryMetadata(story, storyMetadataBySlug);
const resolvedStories = allStories.map((entry) => resolveStoryMetadata(entry, storyMetadataBySlug));
const resolvedStoriesByRouteSlug = new Map(
  resolvedStories
    .filter((entry) => entry.data.language === story.data.language)
    .map((entry) => [getStoryRouteSlug(entry), entry]),
);
const bnStory = findStoryTranslation(allStories, storyRouteSlug, "bn");
const sourceBook = resolvedStory.data.source_slug
  ? bookBySlug.get(resolvedStory.data.source_slug)
  : undefined;
const sourceBookUrl = sourceBook
  ? bookHasDetailPage(sourceBook)
    ? getBookDetailPath(sourceBook.slug)
    : sourceBook.data.library_url || sourceBook.data.url
  : undefined;

const currentUrl = new URL(Astro.url.pathname, Astro.site).toString();
const canonicalUrl = buildCanonicalUrl(Astro.url.pathname, Astro.site);
const alternateLinks = bnStory
  ? [
      { hreflang: "en", href: canonicalUrl },
      {
        hreflang: "bn",
        href: buildCanonicalUrl(`/bn/stories/${getStoryRouteSlug(bnStory)}`, Astro.site),
      },
      { hreflang: "x-default", href: canonicalUrl },
    ]
  : [];
const isBasedOn = sourceBook
  ? {
      "@type": "CreativeWork",
      name: sourceBook.data.name,
      ...(sourceBook.data.author && {
        author: {
          "@type": "Person",
          name: sourceBook.data.author,
        },
      }),
    }
  : null;

const schemaData = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: story.data.title,
  url: canonicalUrl,
  inLanguage: story.data.language,
  author: {
    "@type": "Organization",
    name: "Otibeguni",
    url: buildCanonicalUrl("/", Astro.site),
  },
  publisher: {
    "@type": "Organization",
    name: "Otibeguni",
    url: buildCanonicalUrl("/", Astro.site),
  },
  ...(isBasedOn && { isBasedOn }),
  ...(resolvedStory.data.cover_image && { image: resolvedStory.data.cover_image }),
};

const relatedTopics = (resolvedStory.data.topic_slugs ?? [])
  .map((slug) => topicBySlug.get(slug))
  .filter(Boolean)
  .map((topic) => ({
    name: topic.data.item,
    types: topic.data.types || [],
    url: `/topics/${topic.slug}`,
    isExternal: false,
  }));

const relatedResources = (resolvedStory.data.resource_slugs ?? [])
  .map((slug) => resourceBySlug.get(slug))
  .filter(Boolean)
  .map((resource) => ({
    name: resource.data.title,
    type: resource.data.type,
    url: resource.data.url || "",
    isExternal: true,
  }));
const relatedBlogPosts = allBlogs.filter((post) =>
  post.relatedStorySlugs.includes(storyRouteSlug),
);
const storyCollections = getStoryCollectionsForStory(story, storyCollectionsByStorySlug)
  .map((collection) => ({
    frontmatter: {
      ...collection.data,
      slug: collection.slug,
    },
    stories: (collection.data.stories ?? [])
      .filter((slug) => slug !== storyRouteSlug)
      .map((slug) => resolvedStoriesByRouteSlug.get(slug))
      .filter(Boolean)
      .map((entry) => ({
        frontmatter: { ...entry.data, slug: getStoryRouteSlug(entry) },
      })),
  }))
  .filter((collection) => collection.stories.length > 0);
const breadcrumbs = [
  { label: "Stories", href: "/stories" },
  { label: story.data.title },
];
const sourceText = sourceBook?.data.name || resolvedStory.data.source_label;
const isDev = import.meta.env.DEV;
const availableTopicOptions = [...allTopics]
  .map((topic) => ({
    slug: topic.slug,
    item: topic.data.item,
    types: topic.data.types || [],
  }))
  .sort((left, right) => left.item.localeCompare(right.item));
const availableResourceOptions = [...allResources]
  .map((resource) => ({
    slug: resource.slug,
    title: resource.data.title,
    type: resource.data.type,
    url: resource.data.url || "",
  }))
  .sort((left, right) => left.title.localeCompare(right.title));
---

<Layout
  title={`${story.data.title} - Stories | Otibeguni `}
  schema={schemaData}
  lang="en"
  canonicalUrl={canonicalUrl}
  alternateLinks={alternateLinks}
  breadcrumbs={breadcrumbs}
>
  <main class="pb-8 pt-2 md:pb-12 md:pt-3" data-pagefind-body>
    <div class="w-full">
      <article>
        <StoryHeader story={{ ...resolvedStory.data, slug: storyRouteSlug }}>
          <StoryReadAloudControl
            language="en"
            bodySelector="[data-story-body]"
            idleLabel="Read out loud"
            pauseLabel="Pause reading"
            resumeLabel="Resume reading"
            unavailableTooltip="An English voice needs to be installed in your operating system to use read aloud."
          />
          <StoryMetadata
            slot="metadata"
            category={resolvedStory.data.category}
            sourceBook={sourceText}
            sourceAuthor={sourceBook?.data.author}
            sourceUrl={sourceBookUrl}
            translationLink={bnStory ? `/bn/stories/${getStoryRouteSlug(bnStory)}` : undefined}
            translationLabel="Read in Bengali"
          />
        </StoryHeader>

        <ArticleBody>
          <Content />
        </ArticleBody>

        {
          (relatedTopics.length > 0 || isDev) && (
            <>
              <div class="divider mt-12" />
              <RelatedItemsList
                title="Related Topics"
                items={relatedTopics}
                layout="topic-chips"
                emptyMessage={isDev ? "No related topics yet." : undefined}
              >
                {
                  isDev && (
                    <StoryRelationEditor
                      slot="actions"
                      client:load
                      entityType="topic"
                      storySlug={storyRouteSlug}
                      storyLanguage={story.data.language}
                      currentTopicSlugs={resolvedStory.data.topic_slugs ?? []}
                      currentResourceSlugs={resolvedStory.data.resource_slugs ?? []}
                      availableTopics={availableTopicOptions}
                      availableResources={availableResourceOptions}
                    />
                  )
                }
              </RelatedItemsList>
            </>
          )
        }

        {
          (relatedResources.length > 0 || isDev) && (
            <>
              <div class="divider mt-12" />
              <RelatedItemsList
                title="Related Resources"
                items={relatedResources}
                emptyMessage={isDev ? "No related resources yet." : undefined}
              >
                {
                  isDev && (
                    <StoryRelationEditor
                      slot="actions"
                      client:load
                      entityType="resource"
                      storySlug={storyRouteSlug}
                      storyLanguage={story.data.language}
                      currentTopicSlugs={resolvedStory.data.topic_slugs ?? []}
                      currentResourceSlugs={resolvedStory.data.resource_slugs ?? []}
                      availableTopics={availableTopicOptions}
                      availableResources={availableResourceOptions}
                    />
                  )
                }
              </RelatedItemsList>
            </>
          )
        }

        {
          relatedBlogPosts.length > 0 && (
            <>
              <div class="divider mt-12" />
              <section class="not-prose">
                <h3 class="mb-4 text-2xl font-bold">
                  Related Blog Posts
                </h3>
                <div class="divide-y divide-base-300 border-y border-base-300">
                  {relatedBlogPosts.map((post) => (
                    <BlogCard post={post} path="blog" />
                  ))}
                </div>
              </section>
            </>
          )
        }

        {
          storyCollections.length > 0 && (
            <>
              <div class="divider mt-12" />
              <StoryCollectionList
                title="Story Collections"
                collections={storyCollections}
                path="stories"
              />
            </>
          )
        }
      </article>
    </div>
  </main>
</Layout>
