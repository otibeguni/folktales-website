---
import Layout from "@/layouts/Layout.astro";
import StoryHeader from "../../components/StoryHeader.astro";
import StoryMetadata from "../../components/StoryMetadata.astro";
import ArticleBody from "../../components/ArticleBody.astro";
import RelatedItemsList from "../../components/RelatedItemsList.astro";
import {
  findStoryTranslation,
  getAllBooks,
  getAllResources,
  getAllStories,
  getAllTopics,
  getStoriesByLanguage,
  indexEntriesBySlug,
  renderEntry,
} from "@/utils/content";

export async function getStaticPaths() {
  const stories = await getStoriesByLanguage("en");
  return stories.map((story) => ({
    params: { slug: story.slug },
    props: { story },
  }));
}

const { story } = Astro.props;
const { Content } = await renderEntry(story);

const [allStories, allTopics, allBooks, allResources] = await Promise.all([
  getAllStories(),
  getAllTopics(),
  getAllBooks(),
  getAllResources(),
]);

const topicBySlug = indexEntriesBySlug(allTopics);
const bookBySlug = indexEntriesBySlug(allBooks);
const resourceBySlug = indexEntriesBySlug(allResources);
const bnStory = findStoryTranslation(allStories, story.slug, "bn");
const sourceBook = story.data.source_slug
  ? bookBySlug.get(story.data.source_slug)
  : undefined;

const currentUrl = new URL(Astro.url.pathname, Astro.site).toString();
const isBasedOn = sourceBook
  ? {
      "@type": "CreativeWork",
      name: sourceBook.data.name,
      ...(sourceBook.data.author && {
        author: {
          "@type": "Person",
          name: sourceBook.data.author,
        },
      }),
    }
  : null;

const schemaData = {
  "@context": "https://schema.org",
  "@type": "CreativeWork",
  name: story.data.title,
  url: currentUrl,
  author: {
    "@type": "Organization",
    name: "Otibeguni",
  },
  ...(isBasedOn && { isBasedOn }),
  ...(story.data.cover_image && { image: story.data.cover_image }),
};

const iconMap = {
  Location: "fa-solid fa-location-dot",
  Person: "fa-solid fa-user",
  "Supernatural Entity": "fa-solid fa-ghost",
  River: "fa-solid fa-water",
  video: "fa-solid fa-video",
  website: "fa-solid fa-newspaper",
};

const relatedTopics = (story.data.topic_slugs ?? [])
  .map((slug) => topicBySlug.get(slug))
  .filter(Boolean)
  .map((topic) => ({
    name: topic.data.item,
    type: topic.data.type || "",
    url: `/topics/${topic.slug}`,
    isExternal: false,
  }));

const relatedResources = (story.data.resource_slugs ?? [])
  .map((slug) => resourceBySlug.get(slug))
  .filter(Boolean)
  .map((resource) => ({
    name: resource.data.title,
    type: resource.data.type,
    url: resource.data.url || "",
    isExternal: true,
  }));
---

<Layout
  title={`${story.data.title} - Stories | Otibeguni `}
  schema={schemaData}
>
  <main class="py-8 md:py-12" data-pagefind-body>
    <div class="container mx-auto max-w-4xl px-4">
      <div class="bg-base-100 rounded-xl shadow-lg">
        <article class="p-6 md:p-10">
          <StoryHeader story={{ ...story.data, slug: story.slug }} />

          <StoryMetadata
            category={story.data.category}
            sourceBook={sourceBook?.data.name || story.data.source_label}
            sourceAuthor={sourceBook?.data.author}
            sourceUrl={sourceBook?.data.library_url || sourceBook?.data.url}
            translationLink={bnStory ? `/bn/stories/${bnStory.slug}` : undefined}
            translationLabel="Read in Bengali"
          />

          <div class="divider"></div>

          <ArticleBody>
            <Content />
          </ArticleBody>

          {
            relatedTopics.length > 0 && (
              <>
                <div class="divider mt-12" />
                <RelatedItemsList
                  title="Related Topics"
                  items={relatedTopics}
                  iconMap={iconMap}
                />
              </>
            )
          }

          {
            relatedResources.length > 0 && (
              <>
                <div class="divider mt-12" />
                <RelatedItemsList
                  title="Related Resources"
                  items={relatedResources}
                  iconMap={iconMap}
                />
              </>
            )
          }
        </article>
      </div>
    </div>
  </main>
</Layout>
