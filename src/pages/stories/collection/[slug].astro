---
import Layout from "@/layouts/Layout.astro";
import StoryCollectionList from "@/components/StoryCollectionList.astro";
import {
  getAllStoryCollections,
  getResolvedStories,
  getStoryRouteSlug,
  renderEntry,
} from "@/utils/content";

export async function getStaticPaths() {
  const collections = await getAllStoryCollections();
  return collections.map((collection) => ({
    params: { slug: collection.slug },
    props: { collection },
  }));
}

const { collection } = Astro.props;
const { Content } = await renderEntry(collection);
const storyByRouteSlug = new Map(
  (await getResolvedStories())
    .filter((story) => story.data.language === "en")
    .map((story) => [getStoryRouteSlug(story), story]),
);
const stories = (collection.data.stories ?? [])
  .map((storySlug) => storyByRouteSlug.get(storySlug))
  .filter(Boolean)
  .map((story) => ({
    frontmatter: { ...story.data, slug: getStoryRouteSlug(story) },
  }));
---

<Layout
  title={`${collection.data.title} - Story Collection | Otibeguni `}
  breadcrumbs={[
    { label: "Stories", href: "/stories" },
    { label: collection.data.title },
  ]}
>
  <div class="container mx-auto max-w-4xl px-4 py-8">
    <StoryCollectionList
      collections={[{
        frontmatter: { ...collection.data, slug: collection.slug },
        stories,
        Content,
      }]}
      path="stories"
    />
  </div>
</Layout>
