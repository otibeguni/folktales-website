---
import dayjs from "dayjs";
import { renderRichText } from "@storyblok/astro";
import MarkdownBreadcrumbLayout from "@/layouts/MarkdownBreadcrumbLayout.astro";
import ArticleBody from "@/components/ArticleBody.astro";
import CardStory from "@/components/CardStory";
import BlogCard from "@/components/blog/BlogCard";
import { getBlogPosts } from "@/utils/storyblok-blog";
import { getResolvedStories, getStoryRouteSlug } from "@/utils/content";
import { getYouTubeEmbedUrl, getYouTubeHref } from "@/utils/youtube";
import type { IStoryList } from "@/types";

type StoryblokRichTextNode = {
  type: string;
  content?: StoryblokRichTextNode[];
  text?: string;
  attrs?: {
    id?: string;
    body?: StoryblokBlok[];
  };
};

type StoryblokMultilink = {
  url?: string;
  cached_url?: string;
};

type StoryblokBlok = {
  _uid?: string;
  component?: string;
  youtube_url?: StoryblokMultilink;
  caption?: string;
  tone?: string;
  body?: StoryblokRichTextNode;
  url?: StoryblokMultilink;
  title?: string;
  commentary?: StoryblokRichTextNode;
};

type BodySegment =
    | { kind: "html"; html: string; key: string }
    | { kind: "youtube"; key: string; embedUrl: string; caption: string }
    | { kind: "callout"; key: string; tone: string; html: string }
    | { kind: "linkCommentary"; key: string; href: string; title: string; html: string };

const getRichTextNodes = (body: unknown): StoryblokRichTextNode[] => {
    if (!body || typeof body !== "object") {
        return [];
    }

    const content = (body as { content?: unknown }).content;
    return Array.isArray(content) ? (content as StoryblokRichTextNode[]) : [];
};

const getMultilinkHref = (link?: StoryblokMultilink) =>
  getYouTubeHref(link);

const renderBlock = (blok: StoryblokBlok, index: number): BodySegment | null => {
    const key = blok._uid || `${blok.component || "blok"}-${index}`;

    if (blok.component === "youtube_embed") {
        const embedUrl = getYouTubeEmbedUrl(getMultilinkHref(blok.youtube_url));
        if (!embedUrl) {
            return null;
        }

        return {
            kind: "youtube",
            key,
            embedUrl,
            caption: blok.caption || "",
        };
    }

    if (blok.component === "callout") {
        return {
            kind: "callout",
            key,
            tone: blok.tone || "note",
            html: renderRichText(blok.body),
        };
    }

    if (blok.component === "link_commentary") {
        const href = getMultilinkHref(blok.url);
        if (!href) {
            return null;
        }

        return {
            kind: "linkCommentary",
            key,
            href,
            title: blok.title || href,
            html: renderRichText(blok.commentary),
        };
    }

    return null;
};

const getBodySegments = (body: unknown): BodySegment[] =>
    getRichTextNodes(body).flatMap((node, index) => {
        if (node.type === "blok") {
            const bloks = Array.isArray(node.attrs?.body) ? node.attrs.body : [];
            return bloks
                .map((blok, blokIndex) => renderBlock(blok, blokIndex))
                .filter((segment): segment is BodySegment => Boolean(segment));
        }

        return [
            {
                kind: "html",
                key: `node-${index}`,
                html: renderRichText({
                    type: "doc",
                    content: [node],
                }),
            },
        ];
    });

export async function getStaticPaths() {
  const blogs = await getBlogPosts();
  return blogs.map((blog) => ({
    params: { slug: blog.slug },
    props: { blog },
  }));
}
const { blog } = Astro.props as {
  blog: Awaited<ReturnType<typeof getBlogPosts>>[number];
};
const allBlogs = await getBlogPosts();
const bodySegments = getBodySegments(blog.content?.body);
const isBookmark = blog.postType === "bookmark" && blog.bookmark;
const storyEntries = await getResolvedStories();
const storiesBySlug = new Map<string, IStoryList>();

for (const story of storyEntries.filter((entry) => entry.data.language === "en")) {
  const slug = getStoryRouteSlug(story);
  storiesBySlug.set(slug, {
    frontmatter: { ...story.data, slug },
  });
}

const relatedStories = blog.relatedStorySlugs
  .map((slug) => storiesBySlug.get(slug))
  .filter((story): story is IStoryList => Boolean(story));
const blogsById = new Map(allBlogs.map((post) => [post.id, post]));
const relatedPosts = blog.relatedPostIds
  .map((id) => blogsById.get(id))
  .filter(
    (
      post,
    ): post is Awaited<ReturnType<typeof getBlogPosts>>[number] =>
      Boolean(post) && post.id !== blog.id,
  );
---

<MarkdownBreadcrumbLayout
  title={`${blog.title} - Blog | Otibeguni `}
  description={blog.seoDescription || blog.summary}
  breadcrumbs={[
    { label: "Blog", href: "/blog" },
    { label: blog.title },
  ]}
>
  <div data-pagefind-body>
    <ArticleBody>
      {blog.coverMedia?.type === "youtube" && (
        <figure class="mx-auto mb-6 overflow-hidden rounded-2xl border border-base-300 bg-base-200 shadow-sm">
          <div class="relative w-full" style="padding-top: 56.25%;">
            <iframe
              src={blog.coverMedia.embedUrl}
              title={`${blog.title} cover video`}
              class="absolute inset-0 h-full w-full"
              loading="lazy"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              referrerpolicy="strict-origin-when-cross-origin"
              allowfullscreen
            />
          </div>
        </figure>
      )}
      {blog.coverMedia?.type === "image" && (
        <div class="mx-auto mb-6 max-w-xs overflow-hidden rounded-xl sm:max-w-sm">
          <img
            src={blog.coverMedia.src}
            alt={blog.coverMedia.alt || blog.title}
            class="aspect-square w-full object-cover block"
            loading="lazy"
          />
        </div>
      )}
      <h1 class="mb-4 text-5xl leading-16">{blog.title}</h1>
      <div class="mb-6 flex flex-wrap items-center gap-3">
        <span class="badge badge-soft badge-primary"
          >{dayjs(blog.publishedAt).format("MMM DD YYYY")}</span
        >
        {isBookmark && (
          <span class="badge badge-outline">Bookmark</span>
        )}
      </div>
      {isBookmark && (
        <section class="my-8 overflow-hidden rounded-2xl border border-base-300 bg-base-100 shadow-sm">
          <div class="border-b border-base-300 px-5 py-4">
            <p class="text-xl font-semibold">
              <a href={blog.bookmark.url} target="_blank" rel="noreferrer">
                {blog.bookmark.linkText}
              </a>
            </p>
          </div>
          <div class="space-y-4 px-5 py-5">
            {blog.bookmark.commentary && (
              <p class="m-0 text-lg leading-8 text-base-content/80">
                {blog.bookmark.commentary}
              </p>
            )}
            <div>
              <a class="btn btn-primary" href={blog.bookmark.url} target="_blank" rel="noreferrer">
                Read the full article
              </a>
            </div>
          </div>
        </section>
      )}
      {
        bodySegments.map((segment) => {
          if (segment.kind === "html") {
            return <Fragment set:html={segment.html} />;
          }

          if (segment.kind === "youtube") {
            return (
              <figure class="my-8">
                <div class="overflow-hidden rounded-2xl border border-base-300 bg-base-200 shadow-sm">
                  <div class="relative w-full" style="padding-top: 56.25%;">
                    <iframe
                      src={segment.embedUrl}
                      title={`${blog.title} video`}
                      class="absolute inset-0 h-full w-full"
                      loading="lazy"
                      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                      referrerpolicy="strict-origin-when-cross-origin"
                      allowfullscreen
                    />
                  </div>
                </div>
                {segment.caption && (
                  <figcaption class="mt-3 text-sm text-base-content/70">
                    {segment.caption}
                  </figcaption>
                )}
              </figure>
            );
          }

          if (segment.kind === "callout") {
            const toneClasses = {
              note: "border-info/40 bg-info/10",
              warning: "border-warning/40 bg-warning/10",
              success: "border-success/40 bg-success/10",
            } as const;
            const classes =
              toneClasses[segment.tone as keyof typeof toneClasses] ||
              toneClasses.note;

            return (
              <aside class={`my-8 rounded-2xl border px-5 py-4 ${classes}`}>
                <div set:html={segment.html} />
              </aside>
            );
          }

          return (
            <section class="my-8 rounded-2xl border border-base-300 bg-base-100 p-5 shadow-sm">
              <p class="mb-3 text-sm font-semibold uppercase tracking-wide text-base-content/60">
                Link
              </p>
              <p class="mb-3 text-lg font-semibold">
                <a href={segment.href} target="_blank" rel="noreferrer">
                  {segment.title}
                </a>
              </p>
              <div set:html={segment.html} />
            </section>
          );
        })
      }
      {relatedStories.length > 0 && (
        <section class="mt-12">
          <h2 class="mb-6 border-l-4 border-primary pl-4 text-2xl font-bold md:text-3xl">
            Related Stories
          </h2>
          <div class="flex flex-col gap-4">
            {relatedStories.map((story) => (
              <CardStory
                frontmatter={story.frontmatter}
                coverImage={story.frontmatter.cover_image}
                path="stories"
              />
            ))}
          </div>
        </section>
      )}
      {relatedPosts.length > 0 && (
        <section class="mt-12 not-prose">
          <h2 class="mb-6 border-l-4 border-primary pl-4 text-2xl font-bold md:text-3xl">
            Related Posts
          </h2>
          <div class="divide-y divide-base-300 border-y border-base-300">
            {relatedPosts.map((post) => (
              <BlogCard post={post} path="blog" />
            ))}
          </div>
        </section>
      )}
    </ArticleBody>
  </div>
</MarkdownBreadcrumbLayout>
