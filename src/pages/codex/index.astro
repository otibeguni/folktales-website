---
import { currentLanguage, t } from "@/utils/site-text";
import StoryListCodex from "@/components/StoryListCodex";
import Layout from "@/layouts/Layout.astro";
import { getAllCodexEntries } from "@/utils/content";

const codexstories = (await getAllCodexEntries()).map((entry) => ({
  frontmatter: { ...entry.data, slug: entry.slug },
}));
---

<Layout
  title={"Codex | " + t("common.siteTitle")}
  breadcrumbs={[{ label: "Codex", href: "/codex" }]}
>
  <div class="container mx-auto max-w-4xl px-4 py-8">
    <StoryListCodex
      stories={codexstories}
      lang={currentLanguage}
      labels={{
        filterLabel: t("pages.stories.filterLabel"),
        languageLabel: t("pages.stories.languageLabel"),
        categoryLabel: t("pages.stories.categoryLabel"),
        allCategoryLabel: t("pages.stories.allCategoryLabel"),
      }}
      path="codex"
      client:load
    />
  </div>
</Layout>
